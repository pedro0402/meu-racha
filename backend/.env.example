# Porta do servidor
PORT=3001

# URL do frontend (usado para CORS e para construir o link compartilhável)
# Em produção, você pode informar múltiplas origens separadas por vírgula
# (ex.: domínio principal + preview do Vercel).
FRONTEND_URL=http://localhost:5173

# ---------- Banco (Postgres/Supabase) ----------
# Para migração ao Supabase, configure DATABASE_URL com a connection string
# do Transaction Pooler. Exemplo:
# postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Se vazio, o backend continua usando SQLite local.
DATABASE_URL=
# Use "require" na maioria dos ambientes em nuvem. Em desenvolvimento local,
# você pode deixar vazio.
DATABASE_SSL=require

# Limite de jogadores por racha
MAX_JOGADORES=18

# (Fallback) Dia da semana permitido (0 = domingo, 1 = segunda ... 6 = sábado).
# Só se aplica a rachas criados sem data_abertura específica.
DIA_PERMITIDO=0

# (Fallback) Hora mínima para abrir a lista (formato 24h)
HORA_MINIMA=12

# Fuso horário oficial do servidor (regra de negócio)
TIMEZONE=America/Sao_Paulo

# Tempo de vida do token descartável para entrar na lista (GET …/token-entrada), em ms. Default 900000 = 15 min.
ENTRADA_TOKEN_TTL_MS=900000
